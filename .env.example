# ============================================
# CircleSfera Backend - Variables de Entorno
# ============================================
# IMPORTANTE: NO commits este archivo con valores reales
# Copia a .env y configura con tus valores

# ENTORNO
NODE_ENV=development
PORT=5001
LOG_LEVEL=info

# BASE DE DATOS - MongoDB Atlas (SIEMPRE usar cloud, NO local)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/circlesfera?retryWrites=true&w=majority

# SEGURIDAD - JWT (CRÍTICO: Usar al menos 32 caracteres aleatorios)
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-please-change-this
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# REDIS (Caché y Blacklist de Tokens)
REDIS_URL=redis://localhost:6379

# CORS - URLs permitidas (separadas por coma, sin espacios extra)
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# URLs PÚBLICAS (REQUERIDAS EN PRODUCCIÓN)
APP_URL=http://localhost:5001
API_URL=http://localhost:5001

# CONTACTO / SOPORTE
CONTACT_EMAIL=contact@circlesfera.com
SUPPORT_EMAIL=support@circlesfera.com
CONTACT_URL=https://github.com/circlesfera

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# PAGINACIÓN
DEFAULT_PAGE_LIMIT=10
MAX_PAGE_LIMIT=100

# ARCHIVOS
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600
MAX_FILES_COUNT=10
MAX_IMAGE_SIZE=10485760
MAX_VIDEO_SIZE=104857600

# VALIDACIÓN
MIN_SEARCH_LENGTH=2
MIN_PASSWORD_LENGTH=8

# FEATURES FLAGS
FEATURES_STORIES=true
FEATURES_REELS=true
FEATURES_LIVE=true
FEATURES_MESSAGES=true

# SERVICIOS EXTERNOS (Opcional)
# SENTRY_DSN=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# WEBSOCKETS
WS_PORT=5000
WS_PATH=/socket.io

# SWAGGER
SWAGGER_ENABLED=true
API_DOCS_PATH=/api-docs
