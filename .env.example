# ==========================================
# CONFIGURACIÓN DE CIRCLESFERA - BACKEND
# ==========================================
# Copia este archivo a .env y configura los valores reales

# ==========================================
# SERVIDOR
# ==========================================
NODE_ENV=development
PORT=5001

# ==========================================
# BASE DE DATOS
# ==========================================
# MongoDB Atlas URI (requerido)
MONGODB_URI=mongodb+srv://tu-usuario:tu-password@cluster.mongodb.net/circlesfera?retryWrites=true&w=majority

# ==========================================
# SEGURIDAD Y AUTENTICACIÓN
# ==========================================
# Secret para JWT (genera uno aleatorio)
JWT_SECRET=tu_secret_super_seguro_aqui

# Tiempo de expiración del token JWT
JWT_EXPIRES_IN=30d

# Salt rounds para bcrypt
BCRYPT_SALT_ROUNDS=12

# ==========================================
# CORS
# ==========================================
CORS_ORIGIN=http://localhost:3000

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# SUBIDA DE ARCHIVOS
# ==========================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=104857600
MAX_FILES_COUNT=10

# ==========================================
# PAGINACIÓN
# ==========================================
DEFAULT_PAGE_LIMIT=10
MAX_PAGE_LIMIT=100

# ==========================================
# VALIDACIÓN
# ==========================================
MIN_SEARCH_LENGTH=2
MIN_PASSWORD_LENGTH=8

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info

# ==========================================
# REDIS (Opcional - Para Caching)
# ==========================================
# URL de Redis (opcional, mejora rendimiento)
# REDIS_URL=redis://localhost:6379

# ==========================================
# SENTRY (Opcional - Monitoring)
# ==========================================
# DSN de Sentry para monitoreo de errores en producción
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ==========================================
# CRON JOBS
# ==========================================
# Habilitar cron jobs (backups, limpieza, etc.)
ENABLE_CRON_JOBS=false

# Habilitar backup automático diario
ENABLE_AUTO_BACKUP=false

# ==========================================
# FEATURES FLAGS
# ==========================================
# Habilitar diferentes features
ENABLE_REDIS_CACHE=false
ENABLE_SENTRY_MONITORING=false
