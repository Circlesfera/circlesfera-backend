{
  "name": "circlesfera-backend",
  "version": "1.0.0",
  "description": "Backend API para CircleSfera - Plataforma social moderna",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check && npm run test",
    "verify": "npm run lint && npm run format:check",
    "validate": "npm run check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Circlesfera/circlesfera-backend.git"
  },
  "keywords": [
    "social-media",
    "api",
    "express",
    "mongodb",
    "nodejs"
  ],
  "author": "CircleSfera Team",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Circlesfera/circlesfera-backend/issues"
  },
  "homepage": "https://github.com/Circlesfera/circlesfera-backend#readme",
  "dependencies": {
    "@sentry/node": "^7.120.4",
    "@sentry/profiling-node": "^1.3.5",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dompurify": "^3.2.7",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.1",
    "helmet": "^7.2.0",
    "ioredis": "^5.8.1",
    "isomorphic-dompurify": "^2.28.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.17.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "redis": "^4.7.1",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.18.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.3",
    "mongodb-memory-server": "^9.5.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.2.5",
    "supertest": "^7.1.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
